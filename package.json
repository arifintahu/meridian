{
  "name": "dlmm-agent",
  "version": "1.0.0",
  "type": "module",
  "description": "Autonomous DLMM LP agent for Meteora on Solana",
  "main": "index.js",
  "bin": {
    "meridian": "cli.js"
  },
  "scripts": {
    "setup": "node setup.js",
    "env:encrypt": "node scripts/envrypt.js encrypt",
    "start": "node index.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart meridian --update-env",
    "pm2:logs": "pm2 logs meridian --lines 100",
    "dev": "cross-env DRY_RUN=true node index.js",
    "test": "npm run test:syntax",
    "test:syntax": "find . -path ./node_modules -prune -o -name '*.js' -exec node --check {} \\;",
    "test:screen": "node test/test-screening.js",
    "test:experiment": "node --test test/experiment/db.test.js test/experiment/recorder.test.js",
    "test:unit": "node --test --test-force-exit test/dry-run-pnl.test.js test/config-snapshot.test.js test/low-yield-gate.test.js test/instruction-parser.test.js test/reports.test.js test/fetch-timeout.test.js test/in-range-drawdown.test.js test/severe-trailing-drop.test.js test/max-volatility-filter.test.js test/upside-rebalance.test.js test/rebalance-value-split.test.js test/config-value-coercion.test.js",
    "pg:up": "docker compose up -d",
    "pg:down": "docker compose down",
    "pg:migrate": "node scripts/pg-migrate.js",
    "postinstall": "node scripts/patch-anchor.js"
  },
  "knip": {
    "ignore": [
      "discord-listener/**"
    ]
  },
  "dependencies": {
    "@meteora-ag/dlmm": "1.9.4",
    "@solana/web3.js": "^1.95.0",
    "better-sqlite3": "^9.6.0",
    "bn.js": "^5.2.1",
    "bs58": "^5.0.0",
    "dotenv": "^17.3.1",
    "jsonrepair": "^3.13.3",
    "node-cron": "^3.0.3",
    "openai": "^4.73.0",
    "pg": "^8.13.0",
    "uuid": "^10.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0"
  }
}
